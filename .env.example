# Copy to .env and adjust as needed.
GR4_ENV_NAME=local

# Ports
GR4_CONTROL_PLANE_PORT=8080
GR4_STUDIO_PORT=5173

# Service wiring
GR4_CONTROL_PLANE_URL=http://127.0.0.1:${GR4_CONTROL_PLANE_PORT}

# Workspace layout (defaults are relative to repo root)
GR4_SRC_DIR=src
GR4_BUILD_DIR=build
GR4_PREFIX_DIR=install

# Toolchain / build tools
# Uncomment to opt into the clang toolchain override used by gr4-prefix.
#GR4_CC=clang-20
#GR4_CXX=clang++-20
GR4_PKGCONF=pkgconf

# Optional runtime knobs
GR4_LOG_LEVEL=info
GR4_DEBUG=0
